{
  "title": "AgentOS Production Dashboard",
  "uid": "agentos-main",
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/min)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{
        "expr": "rate(agentos_requests_total[1m]) * 60",
        "legendFormat": "req/min"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "P95 Latency (ms)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(agentos_request_latency_ms_bucket[5m]))",
        "legendFormat": "P95"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2000 },
              { "color": "red", "value": 5000 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Eval Pass Rate",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [{
        "expr": "agentos_eval_pass_rate",
        "legendFormat": "Pass Rate"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.85 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Total Tokens Used Today",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [{
        "expr": "increase(agentos_tokens_total[24h])",
        "legendFormat": "tokens"
      }],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 5,
      "title": "Request Latency Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{
        "expr": "rate(agentos_request_latency_ms_bucket[5m])",
        "legendFormat": "{{provider}}"
      }]
    },
    {
      "id": 6,
      "title": "Provider Request Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [{
        "expr": "increase(agentos_requests_total[1h])",
        "legendFormat": "{{provider}}"
      }]
    },
    {
      "id": 7,
      "title": "Agent Latency by Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(agentos_agent_latency_ms_bucket[5m]))",
        "legendFormat": "{{agent}} P95"
      }],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    },
    {
      "id": 8,
      "title": "Eval Score Distribution",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(agentos_eval_score_bucket{metric='faithfulness'}[5m]))",
          "legendFormat": "Faithfulness P50"
        },
        {
          "expr": "histogram_quantile(0.5, rate(agentos_eval_score_bucket{metric='answer_relevancy'}[5m]))",
          "legendFormat": "Relevancy P50"
        },
        {
          "expr": "histogram_quantile(0.5, rate(agentos_eval_score_bucket{metric='context_precision'}[5m]))",
          "legendFormat": "Precision P50"
        }
      ]
    },
    {
      "id": 9,
      "title": "Retry Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [{
        "expr": "rate(agentos_retries_total[5m])",
        "legendFormat": "{{from_provider}} → {{to_provider}}"
      }]
    }
  ]
}
