# ─── LLM Providers ───────────────────────────────────────────────────────────
# Azure OpenAI (Primary)
AZURE_OPENAI_API_KEY=your_azure_key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Anthropic Claude (Fallback 1)
ANTHROPIC_API_KEY=your_anthropic_key

# Google Gemini (Fallback 2)
GOOGLE_API_KEY=your_google_key

# ─── Databases ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://agentos:secret@localhost:5432/agentos
REDIS_URL=redis://localhost:6379/0

# ─── Auth ─────────────────────────────────────────────────────────────────────
SECRET_KEY=super-secret-change-in-prod-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Observability ────────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_key
LANGCHAIN_PROJECT=agentos-prod

# ─── Search ───────────────────────────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_key

# ─── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_AGENT_EVENTS=agent-events
KAFKA_TOPIC_EVAL_RESULTS=eval-results

# ─── App Config ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
MAX_CONCURRENT_SESSIONS=100
RATE_LIMIT_PER_MINUTE=60

# ─── RAG ──────────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ─── Code Execution ───────────────────────────────────────────────────────────
CODE_EXEC_TIMEOUT=30
CODE_EXEC_MAX_MEMORY_MB=256
