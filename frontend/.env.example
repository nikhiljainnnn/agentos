# ─── AgentOS Frontend Environment Variables ───────────────────────────────────
# Copy this file to .env.local for local development.
# For Vercel deployment, add these as Environment Variables in the Vercel dashboard.

# HTTP API base URL for the backend gateway.
# Local:       http://localhost:8000
# Production:  https://your-ngrok-url.ngrok-free.app  (or your VPS/cloud URL)
VITE_API_URL=http://localhost:8000

# WebSocket base URL. If not set, it is auto-derived from VITE_API_URL
# (http → ws, https → wss). Only set this manually if they differ.
# VITE_WS_URL=ws://localhost:8000
